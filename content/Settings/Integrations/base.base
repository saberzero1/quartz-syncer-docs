views:
  - type: table
    name: Table
    filters:
      not:
        - file.name.startsWith("_")
  - type: cards
    name: Card View
    filters:
      and:
        - '!file.path.startsWith("tags/")'
        - file.ext == "md"
    order:
      - tags
      - file.name
      - description
    sort:
      - property: file.path
        direction: ASC
